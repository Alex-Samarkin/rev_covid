    </mxCell>

    <mxCell id="step3_box" value="&lt;b&gt;Метод Нелдера–Мида (мультистарт)&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;15 независимых стартов:&lt;br/&gt;  • 1 старт из θ&lt;sub&gt;grid&lt;/sub&gt;&lt;br/&gt;  • 14 стартов: θ&lt;sub&gt;grid&lt;/sub&gt; + ε&lt;sub&gt;i&lt;/sub&gt; (Гауссов шум)&lt;br/&gt;    σ&lt;sub&gt;β&lt;/sub&gt;=0.3, σ&lt;sub&gt;μ&lt;/sub&gt;=0.8, σ&lt;sub&gt;E,I&lt;/sub&gt;=1.0, σ&lt;sub&gt;N&lt;/sub&gt;=0.4&lt;br/&gt;&lt;br/&gt;Каждый прогон: до 6 000 итераций&lt;br/&gt;Допуск: gtol = 10⁻⁸&lt;br/&gt;Seed = BASE_SEED + k (воспроизводимость)&lt;br/&gt;&lt;br/&gt;→ Отбор 3 лучших кандидатов по min L" 
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde8ec;strokeColor=#e94560;fontSize=10;fontColor=#1a1a2e;arcSize=8;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=6;" 
      vertex="1" parent="1">
      <mxGeometry x="980" y="95" width="260" height="200" as="geometry" />
    </mxCell>

    <mxCell id="step3_cost" value="📊 ≤ 90 000 вызовов решателя (15 × 6 000 итер.)" 
      style="text;html=1;strokeColor=#e94560;fillColor=#fcd0d8;align=center;verticalAlign=middle;fontSize=9;rounded=1;fontColor=#e94560;" 
      vertex="1" parent="1">
      <mxGeometry x="980" y="305" width="260" height="26" as="geometry" />
    </mxCell>

    <mxCell id="step3_out" value="3 кандидата: θ&lt;sub&gt;c1&lt;/sub&gt;, θ&lt;sub&gt;c2&lt;/sub&gt;, θ&lt;sub&gt;c3&lt;/sub&gt;" 
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;fontColor=#1a1a2e;" 
