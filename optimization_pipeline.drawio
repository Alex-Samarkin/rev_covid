    </mxCell>

    <mxCell id="step4_box" value="&lt;b&gt;Квазиньютоновская полировка (L-BFGS)&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;3 независимых прогона L-BFGS&lt;br/&gt;(по одному от каждого кандидата)&lt;br/&gt;&lt;br/&gt;До 10 000 итераций на прогон&lt;br/&gt;Допуск: gtol = 10⁻¹⁰&lt;br/&gt;Численный градиент (конечные разности)&lt;br/&gt;&lt;br/&gt;Низкоранговое приближение гессиана&lt;br/&gt;→ суперлинейная сходимость&lt;br/&gt;&lt;br/&gt;→ Выбор θ* с глобальным min L" 
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5ed;strokeColor=#2d9966;fontSize=10;fontColor=#1a1a2e;arcSize=8;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=6;" 
      vertex="1" parent="1">
      <mxGeometry x="1300" y="95" width="260" height="200" as="geometry" />
    </mxCell>

    <mxCell id="step4_cost" value="📊 ≤ 30 000 вызовов решателя (3 × 10 000 итер.)" 
      style="text;html=1;strokeColor=#2d9966;fillColor=#c8f0d8;align=center;verticalAlign=middle;fontSize=9;rounded=1;fontColor=#2d9966;" 
      vertex="1" parent="1">
      <mxGeometry x="1300" y="305" width="260" height="26" as="geometry" />
    </mxCell>

    <!-- финальный результат -->
    <mxCell id="step4_out" value="θ* = (β*, μ*, E₀*, I₀*, N*&lt;sub&gt;eff&lt;/sub&gt;[, α*&lt;sub&gt;k&lt;/sub&gt;])" 
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#2d9966;fontSize=11;fontStyle=1;fontColor=#1a1a2e;strokeWidth=2;" 
