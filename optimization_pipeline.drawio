      edge="1" source="step2_out" target="step3_box" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════
         ШАГ 3 — NELDER-MEAD × 15 СТАРТОВ
    ═══════════════════════════════════════════════════════════════ -->

    <mxCell id="step3_bg" value="" 
