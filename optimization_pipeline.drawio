    <mxCell id="title" value="Трёхступенчатая стратегия численной оптимизации (калибровка волны k)" 
      style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#1a1a2e;" 
      vertex="1" parent="1">
      <mxGeometry x="60" y="30" width="1530" height="40" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════
         ВХОДНЫЕ ДАННЫЕ
    ═══════════════════════════════════════════════════════════════ -->
    <mxCell id="input" value="&lt;b&gt;Входные данные волны k&lt;/b&gt;&lt;br/&gt;obs_cases[1..T], obs_deaths[1..T]&lt;br/&gt;σ_k, γ_k (фиксированы из штаммов)&lt;br/&gt;μ_prior, β_prior (стартовые ориентиры)" 
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontColor=#1a1a2e;arcSize=12;align=center;verticalAlign=middle;" 
      vertex="1" parent="1">
      <mxGeometry x="60" y="110" width="240" height="100" as="geometry" />
    </mxCell>

    <!-- стрелка: Input → Step 1 -->
    <mxCell id="arrow_in_1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#1a1a2e;strokeWidth=2;endArrow=block;endFill=1;" 
      edge="1" source="input" target="step1_box" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════
         ШАГ 1 — АНАЛИТИЧЕСКОЕ ПРЕДОБУСЛОВЛИВАНИЕ
    ═══════════════════════════════════════════════════════════════ -->

    <!-- шапка -->
    <mxCell id="step1_header" value="ШАГ 1" 
      style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#ffffff;" 
      vertex="1" parent="1">
      <mxGeometry x="350" y="70" width="240" height="24" as="geometry" />
    </mxCell>

    <!-- фоновый блок -->
    <mxCell id="step1_bg" value="" 
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#0f3460;arcSize=6;" 
      vertex="1" parent="1">
      <mxGeometry x="340" y="65" width="260" height="30" as="geometry" />
    </mxCell>

    <!-- основной блок -->
    <mxCell id="step1_box" value="&lt;b&gt;Аналитическое предобусловливание&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;① Оценка r&lt;sub&gt;est&lt;/sub&gt; из лог-линейной регрессии&lt;br/&gt;    ранней фазы роста (МНК)&lt;br/&gt;&lt;br/&gt;② β₀ = (r&lt;sub&gt;est&lt;/sub&gt; + σ)(r&lt;sub&gt;est&lt;/sub&gt; + γ + μ) / σ&lt;br/&gt;&lt;br/&gt;③ N&lt;sub&gt;eff,0&lt;/sub&gt; = C&lt;sub&gt;peak&lt;/sub&gt; · R₀ / (R₀ − 1)&lt;br/&gt;&lt;br/&gt;④ I₀ ← обратная экстраполяция от пика&lt;br/&gt;   E₀ = I₀ · (γ + μ) / σ" 
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4fd;strokeColor=#0f3460;fontSize=10;fontColor=#1a1a2e;arcSize=8;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=6;spacingTop=4;spacingBottom=4;" 
      vertex="1" parent="1">
      <mxGeometry x="340" y="95" width="260" height="200" as="geometry" />
    </mxCell>

    <!-- нижний тег: стоимость -->
    <mxCell id="step1_cost" value="📊 ~1 вызов решателя (линейная аппроксимация)" 
      style="text;html=1;strokeColor=#0f3460;fillColor=#c8e6f5;align=center;verticalAlign=middle;fontSize=9;rounded=1;fontColor=#0f3460;" 
      vertex="1" parent="1">
      <mxGeometry x="340" y="305" width="260" height="26" as="geometry" />
    </mxCell>

    <!-- выход шага 1 -->
    <mxCell id="step1_out" value="θ₀ = (β₀, μ₀, E₀, I₀, N&lt;sub&gt;eff,0&lt;/sub&gt;)" 
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;fontColor=#1a1a2e;" 
      vertex="1" parent="1">
      <mxGeometry x="362" y="345" width="216" height="44" as="geometry" />
    </mxCell>

    <!-- стрелка внутри шага 1 -->
    <mxCell id="a1_out" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0f3460;strokeWidth=1.5;endArrow=block;endFill=1;" 
      edge="1" source="step1_box" target="step1_out" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- стрелка Step 1 → Step 2 -->
    <mxCell id="arrow_1_2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1a1a2e;strokeWidth=2;endArrow=block;endFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" 
      edge="1" source="step1_out" target="step2_box" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════
         ШАГ 2 — СЕТОЧНЫЙ ПОИСК
    ═══════════════════════════════════════════════════════════════ -->

    <mxCell id="step2_bg" value="" 
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#533483;arcSize=6;" 
      vertex="1" parent="1">
      <mxGeometry x="660" y="65" width="260" height="30" as="geometry" />
    </mxCell>
    <mxCell id="step2_header" value="ШАГ 2" 
      style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#ffffff;" 
      vertex="1" parent="1">
      <mxGeometry x="670" y="70" width="240" height="24" as="geometry" />
    </mxCell>

    <mxCell id="step2_box" value="&lt;b&gt;Двумерный сеточный поиск&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Сетка: β ∈ [β₀/4, 4β₀], 20 точек (лог.)&lt;br/&gt;       N&lt;sub&gt;eff&lt;/sub&gt; ∈ [1.5·C&lt;sub&gt;total&lt;/sub&gt;, N&lt;sub&gt;city&lt;/sub&gt;], 20 точек&lt;br/&gt;&lt;br/&gt;На каждом из 400 узлов:&lt;br/&gt;  μ = μ&lt;sub&gt;prior&lt;/sub&gt; (фиксировано)&lt;br/&gt;  E₀, I₀ ← аналитически из текущих β, N&lt;sub&gt;eff&lt;/sub&gt;&lt;br/&gt;  L(θ) = log-MSE (вызов решателя)&lt;br/&gt;&lt;br/&gt;→ Выбор узла с min L" 
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8fd;strokeColor=#533483;fontSize=10;fontColor=#1a1a2e;arcSize=8;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=6;" 
      vertex="1" parent="1">
      <mxGeometry x="660" y="95" width="260" height="200" as="geometry" />
    </mxCell>

    <mxCell id="step2_cost" value="📊 400 вызовов решателя (полный перебор сетки)" 
      style="text;html=1;strokeColor=#533483;fillColor=#e8d5f5;align=center;verticalAlign=middle;fontSize=9;rounded=1;fontColor=#533483;" 
      vertex="1" parent="1">
      <mxGeometry x="660" y="305" width="260" height="26" as="geometry" />
    </mxCell>

    <mxCell id="step2_out" value="θ&lt;sub&gt;grid&lt;/sub&gt; — лучший узел сетки" 
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;fontColor=#1a1a2e;" 
      vertex="1" parent="1">
      <mxGeometry x="682" y="345" width="216" height="44" as="geometry" />
    </mxCell>

    <mxCell id="a2_out" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#533483;strokeWidth=1.5;endArrow=block;endFill=1;" 
